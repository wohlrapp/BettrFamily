rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Members collection — authenticated users can read/write their own document,
    // and read other members in their family
    match /members/{memberID} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == memberID;
    }

    // Families collection — all authenticated family members have equal access
    match /families/{familyID} {
      allow read: if request.auth != null && isFamilyMember(familyID);
      allow write: if request.auth != null && isFamilyMember(familyID);

      // Sub-collections: all family members can read and write everything
      match /{subcollection}/{document=**} {
        allow read: if request.auth != null && isFamilyMember(familyID);
        allow write: if request.auth != null && isFamilyMember(familyID);
      }
    }

    // Helper: check if user is a member of the family
    function isFamilyMember(familyID) {
      return get(/databases/$(database)/documents/members/$(request.auth.uid)).data.familyGroupID == familyID;
    }
  }
}
